generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== RBAC — 12 ROL =====================
enum Role {
  CUSTOMER
  COURIER
  MERCHANT
  RESTAURANT
  MARKET_OPERATOR
  COFFEE_BRANCH
  DICLEFUL_OPERATOR
  DICLEFUL_DRIVER
  LOAD_CUSTOMER
  CARRIER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  phone         String     @unique
  phoneVerified Boolean    @default(false)
  email         String?    @unique
  name          String?
  surname       String?
  passwordHash  String?
  roles         Role[]     @default([CUSTOMER])
  status        UserStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  otpRequests      OtpRequest[]
  refreshTokens    RefreshToken[]
  addresses        Address[]
  wallets          Wallet[]
  socialIdentities SocialIdentity[]
  ownedStores      Store[]
  cart             Cart?
  orders           Order[]
  deliveries       Delivery[]       @relation("CourierDeliveries")

  verdigiYukler         YukIlani[]          @relation("VerdigiYukler")
  aracIlanlari          AracIlani[]         @relation("AracIlanlari")
  verdigiTeklifler      YukTeklif[]         @relation("VerdigiTeklifler")
  verdigiAracTeklifleri AracTeklif[]        @relation("VerdigiAracTeklifleri")
  komisyonOdemeleri     KomisyonOdeme[]     @relation("KomisyonOdemeleri")
  sozlesmeOnaylari      SozlesmeOnay[]      @relation("SozlesmeOnaylari")
  loadFirmaProfil       LoadFirmaProfil?
  loadTasiyiciProfil    LoadTasiyiciProfil?
  loadBelgeler          LoadBelge[]
  loadPuan              LoadPuan?
  verdigiDegerlendirmeler LoadDegerlendirme[] @relation("VerdigiDegerlendirmeler")
  aldigiDegerlendirmeler  LoadDegerlendirme[] @relation("AldigiDegerlendirmeler")

  @@index([phone])
  @@map("users")
}

model SocialIdentity {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   String
  providerId String
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([userId])
  @@map("social_identities")
}

// ===================== AUTH — OTP + Oturum =====================
enum OtpPurpose {
  LOGIN
  PHONE_VERIFICATION
  PASSWORD_RESET
}

model OtpRequest {
  id         String     @id @default(uuid()) @db.Uuid
  phone      String
  codeHash   String
  purpose    OtpPurpose @default(LOGIN)
  attempts   Int        @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime   @default(now())
  userId     String?    @db.Uuid
  user       User?      @relation(fields: [userId], references: [id])

  @@index([phone, createdAt])
  @@map("otp_requests")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ===================== ADRES =====================
enum AddressType {
  HOME
  WORK
  BILLING
  OTHER
}

model Address {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @db.Uuid
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         AddressType @default(HOME)
  title        String?
  fullName     String?
  phone        String?
  country      String      @default("TR")
  city         String
  district     String?
  neighborhood String?
  line1        String
  line2        String?
  postalCode   String?
  latitude     Float?
  longitude    Float?
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  @@index([userId])
  @@map("addresses")
}

// ===================== FİNANS (double-entry) =====================
enum Currency {
  TRY
  USD
  EUR
}

enum WalletType {
  USER
  MERCHANT
  PLATFORM
  ESCROW
}

model Wallet {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String?    @db.Uuid
  user      User?      @relation(fields: [userId], references: [id])
  type      WalletType @default(USER)
  businessUnit BusinessUnit? // birim defteri (Faz 1'de zorunlulasir)
  currency  Currency   @default(TRY)
  balance   BigInt     @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  entries LedgerEntry[]

  @@unique([userId, type, currency])
  @@map("wallets")
}

enum TransactionType {
  TOPUP
  WITHDRAWAL
  TRANSFER
  PAYMENT
  REFUND
  FEE
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum BusinessUnit {
  MARKET
  YEMEK
  CARSI
  COFFEE
  LOAD
  DICLEFUL
  COURIER
  PLATFORM // cekirdek/holding defteri (cuzdan ops: topup/withdrawal/transfer)
}

model Transaction {
  id           String            @id @default(uuid()) @db.Uuid
  type         TransactionType
  status       TransactionStatus @default(PENDING)
  currency     Currency          @default(TRY)
  amount       BigInt
  orderNo      String?
  businessUnit BusinessUnit
  commission   BigInt            @default(0)
  vat          BigInt            @default(0)
  deliveryFee  BigInt            @default(0)
  netRevenue   BigInt            @default(0)
  reference    String?           @unique
  description  String?
  metadata     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  entries LedgerEntry[]

  deletedAt    DateTime?

  @@index([type, status])
  @@index([businessUnit])
  @@index([orderNo])
  @@map("transactions")
}

enum EntryDirection {
  DEBIT
  CREDIT
}

model LedgerEntry {
  id            String         @id @default(uuid()) @db.Uuid
  transactionId String         @db.Uuid
  transaction   Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  walletId      String         @db.Uuid
  wallet        Wallet         @relation(fields: [walletId], references: [id])
  direction     EntryDirection
  amount        BigInt
  balanceAfter  BigInt
  createdAt     DateTime       @default(now())

  @@index([walletId])
  @@index([transactionId])
  @@map("ledger_entries")
}

// ===================== DENETİM =====================
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  action    String
  entity    String?
  entityId  String?
  ip        String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===================== FAZ 2 — MARKET / KATALOG / SEPET =====================
enum StoreType {
  MARKET
  RESTAURANT
  CAFE
  SHOP
}

model Store {
  id             String       @id @default(uuid()) @db.Uuid
  ownerId        String       @db.Uuid
  owner          User         @relation(fields: [ownerId], references: [id])
  name           String
  slug           String       @unique
  type           StoreType    @default(MARKET)
  businessUnit   BusinessUnit @default(MARKET)
  description    String?
  logoUrl        String?
  phone          String?
  city           String?
  district       String?
  line1          String?
  latitude       Float?
  longitude      Float?
  commissionRate Int          @default(1000) // binde (1000 = %10)
  minOrder       BigInt       @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  categories Category[]
  products   Product[]
  orders     Order[]

  @@index([ownerId])
  @@index([type, isActive])
  @@map("stores")
}

model Category {
  id        String     @id @default(uuid()) @db.Uuid
  storeId   String     @db.Uuid
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  parentId  String?    @db.Uuid
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  products Product[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@map("categories")
}

model Product {
  id              String    @id @default(uuid()) @db.Uuid
  storeId         String    @db.Uuid
  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId      String?   @db.Uuid
  category        Category? @relation(fields: [categoryId], references: [id])
  name            String
  slug            String
  description     String?
  sku             String?
  imageUrl        String?
  price           BigInt // kuruş (minor units)
  currency        Currency  @default(TRY)
  stock           Int       @default(0)
  unit            String?   @default("adet")
  desi            Float     @default(0) // kargo: hacimsel ağırlık (desi)
  weightKg        Float     @default(0) // kargo: fiili ağırlık (kg)
  komisyonTutari  BigInt    @default(0) // muhasebe: komisyon (kuruş) = net × %15
  kargoTutari     BigInt    @default(0) // muhasebe: gömülü kargo + yuvarlama (kuruş)
  malKdvTutari    BigInt    @default(0) // muhasebe: satıcı KDV'si = net × kategori oranı
  hizmetKdvTutari BigInt    @default(0) // muhasebe: platform KDV'si = (komisyon+kargo) × %20
  netFiyat        BigInt    @default(0) // satıcının girdiği net fiyat (kuruş)
  kdvOrani        Int       @default(20) // ürün KDV oranı: 1 / 10 / 20
  satisModeli     String    @default("A") // A=kendi ürün, B=dropshipping
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  cartItems CartItem[]

  @@unique([storeId, slug])
  @@index([storeId, isActive])
  @@index([categoryId])
  @@map("products")
}

model Cart {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId   String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @db.Uuid
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  unitPrice BigInt // ürünün sepete eklendiği andaki fiyatı (kuruş)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@map("cart_items")
}

// ===================== FAZ 3 — SİPARİŞ / ÖDEME (ESCROW) =====================
enum OrderStatus {
  PENDING // oluşturuldu, ödeme bekliyor (kısa geçiş durumu)
  CONFIRMED // ödeme alındı, escrow'da tutuluyor; satıcı onayı bekliyor
  PREPARING // hazırlanıyor
  READY // hazır
  ON_THE_WAY // yolda
  DELIVERED // teslim edildi (escrow dağıtıldı)
  CANCELLED // iptal edildi (müşteriye iade)
  REFUNDED // iade edildi
}

enum PaymentStatus {
  PENDING
  PAID // müşteriden alındı, escrow'da
  RELEASED // satıcı + platforma dağıtıldı
  REFUNDED // müşteriye geri ödendi
}

model Order {
  id            String        @id @default(uuid()) @db.Uuid
  orderNo       String        @unique
  userId        String        @db.Uuid
  user          User          @relation(fields: [userId], references: [id])
  storeId       String        @db.Uuid
  store         Store         @relation(fields: [storeId], references: [id])
  businessUnit  BusinessUnit  @default(MARKET)
  status        OrderStatus   @default(CONFIRMED)
  paymentStatus PaymentStatus @default(PAID)

  subtotal    BigInt // mal toplamı (kuruş)
  deliveryFee BigInt @default(0)
  discount    BigInt @default(0)
  total       BigInt // müşterinin ödediği = subtotal + deliveryFee - discount
  commission  BigInt @default(0) // platform komisyonu
  vat         BigInt @default(0) // komisyon içindeki KDV (raporlama)
  netRevenue  BigInt @default(0) // satıcı hakedişi = subtotal - commission

  addressId    String?   @db.Uuid
  addressText  String?
  contactPhone String? // teslimat adresi anlık kopyası
  note         String?
  placedAt     DateTime  @default(now())
  confirmedAt  DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items    OrderItem[]
  delivery Delivery?

  @@index([userId])
  @@index([storeId, status])
  @@index([orderNo])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid()) @db.Uuid
  orderId   String @db.Uuid
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String @db.Uuid
  name      String // anlık kopya
  unitPrice BigInt // anlık kopya (kuruş)
  quantity  Int
  lineTotal BigInt // unitPrice * quantity

  @@index([orderId])
  @@map("order_items")
}

// ===================== FAZ 4 — KURYE / TESLİMAT =====================
enum DeliveryStatus {
  PENDING // havuzda, kurye bekliyor
  ASSIGNED // kuryeye atandı
  PICKED_UP // kurye aldı, yolda
  DELIVERED // teslim edildi
  CANCELLED // iptal
}

enum DeliveryYontem {
  KENDI // DicleFul kendi kuryesi
  ARACI // dış kargo firması (MNG, Aras, ...)
}

enum KargoFirmasi {
  DICLEFUL
  MNG
  ARAS
  YURTICI
  PTT
  SURAT
  UPS
}

model Delivery {
  id           String         @id @default(uuid()) @db.Uuid
  orderId      String         @unique @db.Uuid
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierId    String?        @db.Uuid
  courier      User?          @relation("CourierDeliveries", fields: [courierId], references: [id])
  status       DeliveryStatus @default(PENDING)
  fee          BigInt         @default(0) // kurye hakedişi (= order.deliveryFee)
  note         String?
  yontem       DeliveryYontem @default(KENDI) // kendi kuryesi mi, aracı kurum mu
  kargoFirmasi KargoFirmasi? // ARACI ise hangi firma
  takipNo      String?        @unique // aracı firmanın takip no'su (public takip anahtarı)
  assignedAt   DateTime?
  pickedUpAt   DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  deletedAt    DateTime?

  @@index([courierId, status])
  @@index([status])
  @@map("deliveries")
}

// ============================================================
// BANİLOAD — Yuk/Arac Ilani + Teklif + Eslestirme (Faz 1)
// (Model/alan adlari Latin harfli Turkce; ekranda tam Turkce gosterilir)
// ============================================================

enum YukIlaniDurum {
  ACIK // ilan acik, teklif bekliyor
  TEKLIF_ALINDI // en az bir teklif geldi
  ESLESTI // teklif kabul edildi, tasiyici belli
  TASINIYOR // yuk yolda
  TAMAMLANDI // teslim edildi, komisyon islendi
  IPTAL // ilan iptal
}

enum AracTipi {
  TIR
  KAMYON
  KAMYONET
  TENTELI
  FRIGORIFIK
  KAPALI_KASA
  ACIK_KASA
  LOWBED
}

enum AracIlaniDurum {
  MUSAIT // bosta, yuk ariyor
  DOLU // bir ise atandi
  PASIF // tasiyici kapatti
  TAMAMLANDI // teslim onaylandi, is bitti (komisyon tahakkuk)
}

enum YukTeklifDurum {
  BEKLIYOR // yuk veren degerlendirsin
  KABUL // kabul edildi (ilan ESLESTI olur)
  RED // reddedildi / baska teklif kabul edildi
  GERI_CEKILDI // tasiyici teklifini cekti
}

enum TeklifTaraf {
  TASIYICI
  FIRMA
}

model YukIlani {
  id                String        @id @default(uuid()) @db.Uuid
  veren             User          @relation("VerdigiYukler", fields: [verenId], references: [id])
  verenId           String        @db.Uuid
  nereden           String // il/ilce (or. "Istanbul / Tuzla")
  nereye            String
  yukTipi           String // "Paletli Urun", "Tekstil", "Mobilya"...
  tonajKg           Int // kilogram cinsinden
  aracTipiIhtiyaci  AracTipi? // istenen arac tipi (opsiyonel)
  yuklemeTarihi     DateTime
  aciklama          String?
  butceKurus        BigInt? // yuk verenin tahmini butcesi (opsiyonel)
  durum             YukIlaniDurum @default(ACIK)
  seciliTeklif      YukTeklif?    @relation("SeciliTeklif", fields: [seciliTeklifId], references: [id])
  seciliTeklifId    String?       @unique @db.Uuid
  teklifler         YukTeklif[]   @relation("IlanTeklifleri")
  teslimBeyanTarihi DateTime? // kamyoncu 'teslim ettim' dedigi an
  teslimOnayTarihi  DateTime? // firma onayladigi an (= gercek teslim tarihi)
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([durum])
  @@index([verenId])
  @@index([durum, yuklemeTarihi])
  @@map("yuk_ilanlari")
}

model AracIlani {
  id                 String         @id @default(uuid()) @db.Uuid
  tasiyici           User           @relation("AracIlanlari", fields: [tasiyiciId], references: [id])
  tasiyiciId         String         @db.Uuid
  aracTipi           AracTipi
  nereden            String // cikis bolgesi
  nereye             String // gidecegi yon
  cikisTarihi        DateTime
  plaka              String?
  teslimBeyanTarihi  DateTime? // kamyoncu teslim beyani
  teslimOnayTarihi   DateTime? // firma onayi (= teslim tarihi)
  kapasiteKg         Int
  beklenenFiyatKurus BigInt? // tasiyicinin bekledigi navlun (opsiyonel)
  deletedAt          DateTime?
  aciklama           String?
  durum              AracIlaniDurum @default(MUSAIT)
  seciliTeklif       AracTeklif?    @relation("SeciliAracTeklif", fields: [seciliTeklifId], references: [id])
  seciliTeklifId     String?        @unique @db.Uuid
  teklifler          AracTeklif[]   @relation("AracIlanTeklifleri")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([durum])
  @@index([tasiyiciId])
  @@index([durum, cikisTarihi])
  @@map("arac_ilanlari")
}

model YukTeklif {
  id               String         @id @default(uuid()) @db.Uuid
  yukIlani         YukIlani       @relation("IlanTeklifleri", fields: [yukIlaniId], references: [id], onDelete: Cascade)
  yukIlaniId       String         @db.Uuid
  tasiyici         User           @relation("VerdigiTeklifler", fields: [tasiyiciId], references: [id])
  tasiyiciId       String         @db.Uuid
  fiyatKurus       BigInt // tasiyicinin teklif ettigi tasima bedeli (kurus)
  plaka            String?
  surucuAdi        String?
  surucuTel        String?
  mesaj            String?
  // Is delili: teklif KABUL edildiginde damgalanir (B modeli - eslesme kaniti)
  kabulTarihi      DateTime?
  kabulIp          String?
  kabulCihaz       String?
  durum            YukTeklifDurum @default(BEKLIYOR)
  beklenenTaraf    TeklifTaraf    @default(TASIYICI) // pazarlik: kimin onayi bekleniyor
  elSayisi         Int            @default(0) // pazarlik el sayisi (3 sinirinda uyari)
  ilkTalepKurus    BigInt? // ilan verenin ilk talebi
  ilkTeklifKurus   BigInt? // teklif verenin ilk teklifi
  gerceklesenKurus BigInt? // anlasilan son tutar (kabul aninda)
  seciliOlan       YukIlani?      @relation("SeciliTeklif")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  deletedAt        DateTime?

  @@index([yukIlaniId])
  @@index([tasiyiciId])
  @@map("yuk_teklifleri")
}

model AracTeklif {
  id               String         @id @default(uuid()) @db.Uuid
  aracIlani        AracIlani      @relation("AracIlanTeklifleri", fields: [aracIlaniId], references: [id], onDelete: Cascade)
  aracIlaniId      String         @db.Uuid
  veren            User           @relation("VerdigiAracTeklifleri", fields: [verenId], references: [id])
  verenId          String         @db.Uuid
  fiyatKurus       BigInt // firmanin teklif ettigi navlun (kurus)
  mesaj            String?
  kabulTarihi      DateTime?
  kabulIp          String?
  kabulCihaz       String?
  durum            YukTeklifDurum @default(BEKLIYOR)
  beklenenTaraf    TeklifTaraf    @default(TASIYICI) // kimin onayi bekleniyor
  elSayisi         Int            @default(0) // pazarlik el sayisi (3 sinirinda uyari)
  ilkTalepKurus    BigInt? // ilan verenin ilk talebi
  ilkTeklifKurus   BigInt? // teklif verenin ilk teklifi
  gerceklesenKurus BigInt? // anlasilan son tutar (kabul aninda)
  seciliOlan       AracIlani?     @relation("SeciliAracTeklif")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  deletedAt        DateTime?

  @@index([aracIlaniId])
  @@index([verenId])
  @@map("arac_teklifleri")
}

// ============================================================
// BANİLOAD — Komisyon Odeme + Borc Takibi (Faz 1 tahsilat)
// Borc = (TAMAMLANDI tasimalarin %5 toplami) - (ONAYLANDI odemeler)
// ============================================================

enum KomisyonOdemeYontem {
  HAVALE // EFT/havale + admin onayi (su an aktif)
  KART // POS entegrasyonu sonrasi aktif olacak
}

enum KomisyonOdemeDurum {
  BEKLIYOR // havale bildirildi, admin onayi bekliyor
  ONAYLANDI // admin onayladi, borc dustu
  RED // reddedildi
}

model KomisyonOdeme {
  id          String              @id @default(uuid()) @db.Uuid
  tasiyici    User                @relation("KomisyonOdemeleri", fields: [tasiyiciId], references: [id])
  tasiyiciId  String              @db.Uuid
  tutarKurus  BigInt // odenen komisyon tutari (kurus)
  yontem      KomisyonOdemeYontem @default(HAVALE)
  durum       KomisyonOdemeDurum  @default(BEKLIYOR)
  dekont      String? // havale dekont/aciklama (kullanici girer)
  adminNot    String? // admin onay/red notu
  deletedAt   DateTime?
  onaylayanId String?             @db.Uuid
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([tasiyiciId])
  @@index([durum])
  @@map("komisyon_odemeleri")
}

// ============================================================
// BANİLOAD — Sozlesme Onay (B modeli)
// Uyelikte TEK ONAY (kullanici basina bir kez, surum bazli).
// Her iste ayri sozlesme YOK; is delili YukTeklif'e gomulu.
// Metin GECICI taslak; avukat onayindan sonra surum guncellenir.
// ============================================================

enum SozlesmeTipi {
  TASIYICI // tasiyici (CARRIER) uyelik sozlesmesi
  YUK_VEREN // yuk veren (LOAD_CUSTOMER) uyelik sozlesmesi
  EVDEN_EVE_TASIYAN // evden eve: tasiyan sozlesmesi (kesif sonrasi kabul aninda)
  EVDEN_EVE_TASITAN // evden eve: tasitan sozlesmesi (kesif sonrasi kabul aninda)
}

model SozlesmeOnay {
  id           String       @id @default(uuid()) @db.Uuid
  kullanici    User         @relation("SozlesmeOnaylari", fields: [kullaniciId], references: [id])
  kullaniciId  String       @db.Uuid
  sozlesmeTipi SozlesmeTipi
  surum        String // onaylanan metin surumu (or. "v1-taslak"); avukat degisince artar
  metinHash    String // onaylanan metnin SHA-256 hash'i (degismedi kaniti)
  ip           String? // onayin geldigi IP (kanit)
  cihaz        String? // user-agent / cihaz (kanit)
  onayTarihi   DateTime     @default(now())
  createdAt    DateTime     @default(now())

  // Her kullanici, her sozlesme tipinin her surumunu BIR KEZ onaylar
  @@unique([kullaniciId, sozlesmeTipi, surum])
  @@index([kullaniciId])
  @@map("sozlesme_onaylari")
}

// ============================================================
//  PARTNER BASVURULARI — satici / franchise / restoran / kurye
//  Tek tablo, tip ayrimli. Tum alanlar opsiyonel (tipe gore dolar).
// ============================================================

enum PartnerBasvuruTip {
  SELLER // Carsi satici basvurusu
  FRANCHISE // Coffee franchise basvurusu
  RESTAURANT // Restoran (Yemek) basvurusu
  COURIER // Kurye basvurusu
}

enum PartnerBasvuruDurum {
  BEKLIYOR // yeni geldi, incelenmedi
  INCELENDI // admin baktı
  ONAYLANDI // kabul edildi
  RED // reddedildi
}

model PartnerBasvuru {
  id    String              @id @default(uuid()) @db.Uuid
  tip   PartnerBasvuruTip
  durum PartnerBasvuruDurum @default(BEKLIYOR)

  // Ortak alanlar (tum formlarda var)
  adSoyad String
  telefon String
  il      String?

  // Tipe ozel alanlar (opsiyonel)
  isletme      String? // SELLER: isletme adi
  restoran     String? // RESTAURANT: restoran adi
  butce        String? // FRANCHISE: yatirim butcesi
  aracTipi     String? // COURIER: arac tipi (motor/bisiklet/araba - serbest)
  businessUnit BusinessUnit? // SELLER icin CARSI vb.

  // Kanit / iletisim
  not   String? // admin notu
  ip    String?
  cihaz String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@index([tip])
  @@index([durum])
  @@map("partner_basvurulari")
}

